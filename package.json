  "private": true,
  "packageManager": "npm@10.2.4",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:with-mermaid": "turbo run render-mermaid dev --parallel",
    "preprocess:content": "node scripts/preprocess-content-simple.js",
    "build": "next build",
    "vercel-build": "next build",
    "build:optimized": "next build",
    "build:clear": "node scripts/optimize-build.js --clear-cache",
    "start": "next start",
    "lint": "next lint",
    "toggle-logs": "node src/scripts/toggleLogging.js",
    "logs:off": "echo 'ENABLE_LOGS=false' > .env && npm run dev",
    "logs:on": "echo 'ENABLE_LOGS=true' > .env && npm run dev",
    "clean": "rm -rf .next",
    "dev:clean": "npm run clean && npm run dev",
    "build:clean": "npm run clean && npm run build",
    "test:content": "node test/test-content.js",
    "preview:test": "node src/scripts/previewTestSite.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "media:sync": "ts-node media/scripts/sync.ts",
    "media:sync:dry": "ts-node media/scripts/sync.ts --dry-run",
    "media:clean": "ts-node media/scripts/clean.ts",
    "media:setup": "ts-node media/scripts/create-bucket.ts",
    "images:audit": "tsx src/utils/imageGeneration.ts audit",
    "images:generate": "node src/utils/imageGeneration.js prompt",
    "images:generate-to": "node src/utils/imageGeneration.js prompt",
    "links:check": "node scripts/link-checker.js",
    "links:check:internal": "node scripts/link-checker.js --skip-external",
    "links:check:external": "node scripts/link-checker.js",
    "dates:check": "node scripts/fix-frontmatter-dates.js --check-only",
    "dates:fix": "node scripts/fix-frontmatter-dates.js",
    "dates:fix:dry": "node scripts/fix-frontmatter-dates.js --dry-run --verbose"
  },
